# Discord Bot Configuration

# Your Discord bot token (get from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# ========================================
# AI Provider Options (choose one):
# ========================================

# Option 1: Use HappyCapy AI Gateway (recommended - uses your HappyCapy credits)
# This is automatically available in HappyCapy environment
# If running outside HappyCapy, get this key from your HappyCapy settings
AI_GATEWAY_API_KEY=

# Option 2: Use Anthropic API directly (requires separate Anthropic account)
# Get from https://console.anthropic.com/
# Uncomment if you want to use direct Anthropic API instead
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Custom AI Gateway URL (leave empty to use default)
AI_GATEWAY_URL=

# ========================================
# Bot Behavior Settings
# ========================================

# Optional: Specific channel ID to monitor for support messages
# If not set, bot will respond in all channels where it has access
DISCORD_SUPPORT_CHANNEL_ID=

# Command prefix for bot commands (default: !)
DISCORD_BOT_PREFIX=!

# Auto-respond to all messages in monitored channels
# Set to 'true' to enable auto-response, or 'false' to only respond when mentioned
AUTO_RESPOND=true
